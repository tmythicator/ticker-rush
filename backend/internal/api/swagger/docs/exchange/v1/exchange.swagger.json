{
  "swagger": "2.0",
  "info": {
    "title": "Exchange Service API",
    "description": "API for stock quotes, market history, and trading.",
    "version": "1.0.0"
  },
  "tags": [
    {
      "name": "ExchangeService"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/api/v1/quotes/events": {
      "get": {
        "summary": "Opens a Server-Sent Events (SSE) stream for real-time stock quote updates.",
        "operationId": "ExchangeService_StreamQuotes",
        "responses": {
          "200": {
            "description": "A successful response.(streaming responses)",
            "schema": {
              "type": "object",
              "properties": {
                "result": {
                  "$ref": "#/definitions/v1StreamQuotesResponse"
                },
                "error": {
                  "$ref": "#/definitions/rpcStatus"
                }
              },
              "title": "Stream result of v1StreamQuotesResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "symbol",
            "description": "Optional ticker symbol to filter updates. If empty, streams all tickers.",
            "in": "query",
            "required": false,
            "type": "string"
          }
        ],
        "tags": [
          "ExchangeService"
        ],
        "security": [
          {
            "CookieAuth": []
          }
        ]
      }
    },
    "/api/v1/quotes/{symbol}": {
      "get": {
        "summary": "Retrieves the current quote and metadata for a single stock.",
        "operationId": "ExchangeService_GetQuote",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1GetQuoteResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "symbol",
            "description": "Stock ticker symbol.",
            "in": "path",
            "required": true,
            "type": "string"
          }
        ],
        "tags": [
          "ExchangeService"
        ],
        "security": [
          {
            "CookieAuth": []
          }
        ]
      }
    },
    "/api/v1/quotes/{symbol}/history": {
      "get": {
        "summary": "Returns historical quote candles for a stock.",
        "operationId": "ExchangeService_GetHistory",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1GetHistoryResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "symbol",
            "description": "Stock ticker symbol.",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "limit",
            "description": "Maximum number of historical records to return.",
            "in": "query",
            "required": false,
            "type": "integer",
            "format": "int32"
          }
        ],
        "tags": [
          "ExchangeService"
        ]
      }
    },
    "/api/v1/trades": {
      "post": {
        "summary": "Places a trade (Buy/Sell) for a stock.",
        "operationId": "ExchangeService_CreateTrade",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1CreateTradeResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "description": "Request payload to place a trade.",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/v1CreateTradeRequest"
            }
          }
        ],
        "tags": [
          "ExchangeService"
        ],
        "security": [
          {
            "CookieAuth": []
          }
        ]
      }
    }
  },
  "definitions": {
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1CreateTradeRequest": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "description": "Stock ticker symbol to trade."
        },
        "quantity": {
          "type": "number",
          "format": "double",
          "description": "Quantity of shares to trade."
        },
        "action": {
          "$ref": "#/definitions/v1TradeAction",
          "description": "Action to perform (Buy or Sell)."
        }
      },
      "description": "Request payload to place a trade.",
      "required": [
        "symbol",
        "quantity",
        "action"
      ]
    },
    "v1CreateTradeResponse": {
      "type": "object",
      "properties": {
        "participant": {
          "$ref": "#/definitions/v1LadderParticipant",
          "description": "Updated standing and portfolio of the participant."
        }
      },
      "description": "Response payload for a trade transaction."
    },
    "v1GetHistoryResponse": {
      "type": "object",
      "properties": {
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1Quote"
          },
          "description": "Historical stock quote entries."
        }
      },
      "description": "Response containing historical quote records."
    },
    "v1GetQuoteResponse": {
      "type": "object",
      "properties": {
        "quote": {
          "$ref": "#/definitions/v1Quote",
          "description": "Current stock quote."
        }
      },
      "description": "Response containing the stock quote."
    },
    "v1LadderParticipant": {
      "type": "object",
      "properties": {
        "ladderId": {
          "type": "string",
          "format": "int64",
          "description": "Identifier of the ladder."
        },
        "user": {
          "$ref": "#/definitions/v1PublicProfile",
          "description": "User profile of the participant."
        },
        "finalRank": {
          "type": "integer",
          "format": "int32",
          "description": "Final rank in the ladder (set after completion)."
        },
        "joinedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the user joined."
        }
      },
      "description": "User standing and status in a ladder.",
      "required": [
        "ladderId",
        "user",
        "joinedAt"
      ]
    },
    "v1PortfolioItem": {
      "type": "object",
      "properties": {
        "stockSymbol": {
          "type": "string",
          "description": "The stock ticker symbol."
        },
        "quantity": {
          "type": "number",
          "format": "double",
          "description": "The quantity of shares owned."
        },
        "averagePrice": {
          "type": "number",
          "format": "double",
          "description": "The average purchase price of the shares."
        }
      },
      "description": "PortfolioItem represents a single stock holding in a user's portfolio."
    },
    "v1PublicProfile": {
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "Username of the account."
        },
        "firstName": {
          "type": "string",
          "description": "First name of the user."
        },
        "lastName": {
          "type": "string",
          "description": "Last name of the user."
        },
        "website": {
          "type": "string",
          "description": "Optional website URL."
        },
        "balance": {
          "type": "number",
          "format": "double",
          "description": "Current cash balance in USD."
        },
        "portfolio": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/v1PortfolioItem"
          },
          "description": "Current stock portfolio holdings."
        },
        "isPublic": {
          "type": "boolean",
          "description": "Whether the profile is public."
        }
      },
      "description": "Public representation of a user profile."
    },
    "v1Quote": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "description": "Stock ticker symbol."
        },
        "price": {
          "type": "number",
          "format": "double",
          "description": "Current price in USD."
        },
        "change": {
          "type": "number",
          "format": "double",
          "description": "Absolute price change compared to the previous close."
        },
        "changePercent": {
          "type": "number",
          "format": "double",
          "description": "Percentage price change compared to the previous close."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the price update."
        },
        "source": {
          "type": "string",
          "description": "Price data provider source."
        },
        "isClosed": {
          "type": "boolean",
          "description": "Indicates if the market is closed for this stock."
        }
      },
      "description": "Real-time stock price data."
    },
    "v1StreamQuotesResponse": {
      "type": "object",
      "properties": {
        "quote": {
          "$ref": "#/definitions/v1Quote",
          "description": "Live stock quote update."
        }
      },
      "description": "Response payload for real-time quote stream."
    },
    "v1TradeAction": {
      "type": "string",
      "enum": [
        "UNSPECIFIED",
        "BUY",
        "SELL"
      ],
      "default": "UNSPECIFIED",
      "description": "Trade action type (Buy or Sell)."
    }
  },
  "securityDefinitions": {
    "CookieAuth": {
      "type": "apiKey",
      "description": "Authentication cookie 'auth_token' containing JWT",
      "name": "auth_token",
      "in": "header"
    }
  }
}
