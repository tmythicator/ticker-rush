{
  "swagger": "2.0",
  "info": {
    "title": "Ladder Service API",
    "description": "API for viewing and participating in competition ladders.",
    "version": "1.0.0"
  },
  "tags": [
    {
      "name": "LadderService"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/api/v1/ladder/active": {
      "get": {
        "summary": "GetActiveLadder retrieves full metadata for the currently active ladder.",
        "operationId": "LadderService_GetActiveLadder",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1GetActiveLadderResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "tags": [
          "LadderService"
        ]
      }
    },
    "/api/v1/ladder/join": {
      "post": {
        "summary": "JoinLadder enrolls the authenticated user into the active ladder competition.",
        "operationId": "LadderService_JoinLadder",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/v1JoinLadderResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "tags": [
          "LadderService"
        ],
        "security": [
          {
            "CookieAuth": []
          }
        ]
      }
    }
  },
  "definitions": {
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "v1GetActiveLadderResponse": {
      "type": "object",
      "properties": {
        "ladder": {
          "$ref": "#/definitions/v1Ladder",
          "description": "Active competition ladder."
        }
      },
      "description": "Response containing active ladder metadata."
    },
    "v1JoinLadderResponse": {
      "type": "object",
      "properties": {
        "success": {
          "type": "boolean",
          "description": "Whether the transaction succeeded."
        },
        "message": {
          "type": "string",
          "description": "Detailed status or error message."
        }
      },
      "description": "Response for joining a ladder."
    },
    "v1Ladder": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "format": "int64",
          "description": "Unique database identifier."
        },
        "name": {
          "type": "string",
          "description": "Name of the competition."
        },
        "type": {
          "type": "string",
          "description": "Type of competition cycle (weekly or monthly)."
        },
        "startTime": {
          "type": "string",
          "format": "date-time",
          "description": "Start time of the competition."
        },
        "endTime": {
          "type": "string",
          "format": "date-time",
          "description": "End time of the competition."
        },
        "isActive": {
          "type": "boolean",
          "description": "Whether the ladder is currently active."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp of the ladder."
        },
        "initialBalance": {
          "type": "number",
          "format": "double",
          "description": "Starting cash balance allocated to participants."
        },
        "allowedTickers": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/v1TickerInfo"
          },
          "description": "List of stock tickers allowed in this competition."
        }
      },
      "description": "Competition cycle or season."
    },
    "v1TickerInfo": {
      "type": "object",
      "properties": {
        "symbol": {
          "type": "string",
          "description": "Stock ticker symbol."
        },
        "source": {
          "type": "string",
          "description": "Source provider for market data."
        }
      },
      "description": "Configuration of an allowed stock in the ladder."
    }
  },
  "securityDefinitions": {
    "CookieAuth": {
      "type": "apiKey",
      "description": "Authentication cookie 'auth_token' containing JWT",
      "name": "auth_token",
      "in": "header"
    }
  }
}
